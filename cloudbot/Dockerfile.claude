FROM node:22-bookworm-slim AS claude-runtime

RUN npm install -g @anthropic-ai/claude-code@2.1.198

FROM python:3.12-slim-bookworm

ENV HOME=/root \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    DISABLE_AUTOUPDATER=1

COPY --from=claude-runtime /usr/local/bin/node /usr/local/bin/node
COPY --from=claude-runtime /usr/local/lib/node_modules /usr/local/lib/node_modules

RUN ln -s /usr/local/lib/node_modules/@anthropic-ai/claude-code/bin/claude.exe /usr/local/bin/claude \
    && ln -s /root/.claude/.claude.json /root/.claude.json \
    && mkdir -p /app /root/.claude /run/claude-ipc

WORKDIR /app
COPY claude_code_client.py claude_sidecar.py ./

CMD ["python", "claude_sidecar.py"]
